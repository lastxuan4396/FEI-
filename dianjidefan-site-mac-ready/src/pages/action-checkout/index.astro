---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  demoPresets,
  engineBlueprint,
  faqItems,
  hardBenefits,
  pageMeta,
  promiseCards,
  qualityLoop,
  queueFamilies,
  resetPrimer,
  roadmap,
  trustRules,
  workflowSteps
} from "../../data/action-checkout";
---
<BaseLayout
  title={pageMeta.title}
  description={pageMeta.description}
  image="/assets/action-checkout-cover.svg"
  canonical="/action-checkout/"
  themeColor="#eef4ea"
>
  <a class="skip-link" href="#action-main">跳到主要内容</a>

  <div class="action-shell">
    <header class="action-header">
      <a class="action-brand" href="/">
        <span class="action-brand-badge">行动收银台</span>
        <span class="action-brand-copy">
          <strong>Action Checkout</strong>
          <small>Task breaker · Daily reset</small>
        </span>
      </a>

      <nav class="action-nav" aria-label="行动收银台页面导航">
        <a href="#overview">概览</a>
        <a href="#why">为什么成立</a>
        <a href="#daily-reset">今日复位</a>
        <a href="#workflow">怎么工作</a>
        <a href="#engine">引擎</a>
        <a href="#demo">体验</a>
        <a href="#faq">FAQ</a>
        <a href="/reset-antechamber/">复位前室</a>
        <a href="/downloads-checkout/">下载区去留器</a>
      </nav>

      <div class="action-header-actions">
        <a class="action-header-link" href="/reset-antechamber/">复位前室</a>
        <a class="action-header-link" href="/downloads-checkout/">文件收银台</a>
        <a class="action-header-link" href="/daijie/">待结概念页</a>
        <a class="action-header-link" href="/">回作品站</a>
      </div>
    </header>

    <main id="action-main" class="action-main">
      <section id="overview" class="hero reveal">
        <div class="hero-copy">
          <p class="section-tag">Action product</p>
          <h1>把大任务，压成下一刀。</h1>
          <p class="hero-lead">{pageMeta.pitch}</p>
          <p class="hero-note">
            这不是另一个待办清单，也不是要你重新设计人生。它只做一件事：
            把“我知道该做，但就是起不来”的那一下，压成一张你愿意先点下去的小动作卡。
          </p>

          <div class="hero-actions">
            <a class="hero-btn hero-btn-primary" href="#demo">试行动原型</a>
            <a class="hero-btn hero-btn-secondary" href="/reset-antechamber/">如果现在太绷，先去前室</a>
            <a class="hero-btn hero-btn-secondary" href="/downloads-checkout/">看文件收银台</a>
            <a class="hero-btn hero-btn-secondary" href="/daijie/">回待结母产品</a>
          </div>

          <div class="hero-metrics" aria-label="行动收银台摘要指标">
            <article>
              <strong>1 张卡</strong>
              <span>只做一刀，不先做完整计划</span>
            </article>
            <article>
              <strong>3 个动作</strong>
              <span>先做 3 分钟 / 稍后 / 换一刀</span>
            </article>
            <article>
              <strong>双入口</strong>
              <span>任务破冰 + 今日复位</span>
            </article>
          </div>
        </div>

        <div class="hero-board" aria-label="行动收银台主张板">
          <article class="board-card board-card-problem">
            <p class="card-kicker">这页抓的问题</p>
            <h2>很多人不是没有任务系统，而是根本没有开始。</h2>
            <p>行动收银台解决的不是“记不住要做什么”，而是“每次都卡在第一刀从哪下”。</p>
          </article>

          <article class="board-card board-card-rules">
            <p class="card-kicker">产品规则</p>
            <ul>
              <li>不许先做复杂规划</li>
              <li>动作必须足够小</li>
              <li>换一刀比硬扛更重要</li>
            </ul>
          </article>

          <article class="board-card board-card-fit">
            <p class="card-kicker">它放在哪</p>
            <h2>和下载区去留器并列，组成待结的双主线。</h2>
            <p>文件收银台负责减法，行动收银台负责开工。一个结对象，一个结阻力。</p>
            <div class="pill-row">
              <span>任务破冰</span>
              <span>今日复位</span>
              <span>浏览器原型</span>
            </div>
          </article>
        </div>
      </section>

      <section id="why" class="content-section reveal">
        <div class="section-head">
          <div>
            <p class="section-tag">Why it works</p>
            <h2>它的正向性，不是“更会规划”，而是“我真的开始了”。</h2>
          </div>
          <p>行动类产品很容易陷入鸡汤或系统过重。行动收银台成立的前提，是让“已经开了一刀”这件事本身变成清晰回报。</p>
        </div>

        <div class="benefit-grid">
          {hardBenefits.map((item) => (
            <article class="benefit-card">
              <strong>{item.value}</strong>
              <p>{item.body}</p>
            </article>
          ))}
        </div>

        <div class="promise-grid">
          {promiseCards.map((item) => (
            <article class="promise-card">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="daily-reset" class="content-section reveal">
        <div class="section-head">
          <div>
            <p class="section-tag">Daily reset</p>
            <h2>今日复位不是大扫除，而是把自己拉回可开始区。</h2>
          </div>
          <p>{resetPrimer.summary}</p>
        </div>

        <div class="reset-framing">
          <article class="reset-framing-card reset-framing-card-main">
            <p class="card-kicker">它在解决什么</p>
            <h3>不是任务太多，而是你当前的状态已经不太能接住任务了。</h3>
            <p>{resetPrimer.framing}</p>
          </article>

          <article class="reset-framing-card">
            <p class="card-kicker">复位成功长什么样</p>
            <ul class="reset-list">
              {resetPrimer.successSigns.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>
        </div>

        <div class="reset-layer-grid">
          {resetPrimer.layers.map((item) => (
            <article class="reset-layer-card">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>

        <article class="reset-anti-card">
          <p class="card-kicker">它不是什么</p>
          <div class="reset-anti-row">
            {resetPrimer.antiGoals.map((item) => (
              <span>{item}</span>
            ))}
          </div>
        </article>

        <article class="reset-anti-card">
          <p class="card-kicker">如果你现在更像“整个人太绷”</p>
          <div class="bridge-actions">
            <a class="hero-btn hero-btn-primary" href="/reset-antechamber/">先去复位前室</a>
            <a class="hero-btn hero-btn-secondary" href="#demo">我已经能接住复位了</a>
          </div>
        </article>
      </section>

      <section id="workflow" class="content-section reveal">
        <div class="section-head">
          <div>
            <p class="section-tag">How it works</p>
            <h2>不是完整任务管理，而是一轮今天就能开始的动作账单。</h2>
          </div>
          <p>输入一句卡住的事，产品先给你一轮小刀。你不需要当场想好全部，只要先做眼前这一笔。</p>
        </div>

        <div class="workflow-grid">
          {workflowSteps.map((step, index) => (
            <article class="workflow-card">
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </article>
          ))}
        </div>

        <div class="family-grid">
          {queueFamilies.map((item) => (
            <article class="family-card">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="engine" class="content-section reveal">
        <div class="section-head">
          <div>
            <p class="section-tag">Hybrid engine</p>
            <h2>回答质量不是靠每次都重想一遍，而是靠先收紧，再升级求精。</h2>
          </div>
          <p>{engineBlueprint.summary}</p>
        </div>

        <div class="engine-grid">
          {engineBlueprint.stages.map((item) => (
            <article class="engine-card">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>

        <div class="engine-lower">
          <article class="engine-rail-card">
            <p class="card-kicker">Cost discipline</p>
            <h3>先让便宜逻辑做大头，再让更贵的推理只出现在该出现的时候。</h3>
            <ul class="trust-list">
              {engineBlueprint.rails.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>

          <article class="engine-rail-card">
            <p class="card-kicker">Quality loop</p>
            <div class="quality-loop">
              {qualityLoop.map((item) => (
                <article class="quality-step">
                  <h3>{item.title}</h3>
                  <p>{item.body}</p>
                </article>
              ))}
            </div>
          </article>
        </div>
      </section>

      <section id="demo" class="content-section reveal">
        <div class="section-head">
          <div>
            <p class="section-tag">Action beta</p>
            <h2>这页不是概念说明，而是一个能把“下一刀”真的排出来的原型。</h2>
          </div>
          <p>先支持两类动作：任务破冰和今日复位。浏览器版先证明交互节奏，不先背上复杂账号体系。</p>
        </div>

        <div class="action-layout">
          <article class="source-panel">
            <div class="source-head">
              <div>
                <p class="card-kicker">Source hub</p>
                <h3>先把卡住的事写进来</h3>
              </div>
              <div class="source-chip-row">
                <span id="action-source-count">本轮 0</span>
                <span id="action-pending-count">待排 0</span>
              </div>
            </div>

            <div class="mode-switch" role="tablist" aria-label="行动模式">
              <button type="button" class="mode-pill is-active" data-action-mode="task" aria-pressed="true">任务破冰</button>
              <button type="button" class="mode-pill" data-action-mode="reset" aria-pressed="false">今日复位</button>
            </div>

            <label class="field-label" for="action-input">输入一句现在最卡的事</label>
            <textarea
              id="action-input"
              class="source-textarea"
              rows="5"
              placeholder="比如：做一份给导师看的汇报 PPT"
            ></textarea>

            <div class="source-actions">
              <button id="action-generate" class="demo-btn demo-btn-primary" type="button">生成这一轮</button>
              <button id="action-load-sample" class="demo-btn" type="button">载入示例</button>
              <button id="action-clear-session" class="demo-btn" type="button">清空本轮</button>
            </div>

            <p id="action-source-status" class="source-status">输入一句现在卡住的事，系统会把它压成几张可以立即开工的小动作卡。</p>

            <article class="engine-live-card">
              <div class="engine-live-head">
                <div>
                  <p class="card-kicker">Engine lane</p>
                  <h3>这一轮现在怎么出卡</h3>
                </div>
                <span id="action-engine-badge" class="engine-badge">规则起手</span>
              </div>

              <div class="engine-live-grid">
                <article>
                  <strong id="action-engine-route">待识别</strong>
                  <span>当前路由</span>
                </article>
                <article>
                  <strong id="action-engine-stage">规则起手</strong>
                  <span>当前层级</span>
                </article>
                <article>
                  <strong id="action-engine-cost">低成本</strong>
                  <span>成本策略</span>
                </article>
              </div>

              <p id="action-engine-note" class="engine-live-note">
                这一版先走规则归类和模板派发。只有继续点“换一刀”时，才会往更深一层求精。
              </p>
            </article>

            <div class="preset-groups">
              <div class="preset-group">
                <p class="card-kicker">任务示例</p>
                <div class="preset-row">
                  {demoPresets.task.map((item) => (
                    <button class="preset-chip" type="button" data-action-mode="task" data-action-preset={item}>
                      {item}
                    </button>
                  ))}
                </div>
              </div>

              <div class="preset-group">
                <p class="card-kicker">复位示例</p>
                <div class="preset-row">
                  {demoPresets.reset.map((item) => (
                    <button class="preset-chip" type="button" data-action-mode="reset" data-action-preset={item}>
                      {item}
                    </button>
                  ))}
                </div>
              </div>
            </div>
          </article>

          <div class="board-shell">
            <div class="board-topbar">
              <div>
                <p class="card-kicker">Today&apos;s cut</p>
                <h3 id="action-queue-title">行动账单</h3>
              </div>
              <div class="queue-counter">
                <span id="action-queue-index">1</span>
                <span>/</span>
                <span id="action-queue-total">1</span>
              </div>
            </div>

            <article class="action-card action-card-main">
              <p id="action-kicker" class="action-card-kicker">任务破冰</p>
              <h3 id="action-title">先输入一句卡住的事</h3>
              <p id="action-meta" class="action-card-meta">行动收银台 · 第一刀</p>
              <p id="action-message" class="action-card-message">
                这不是待办列表，只是今天的一刀。先把动作压到足够小，再决定要不要继续。
              </p>
              <div id="action-tags" class="tag-row">
                <span>先开工</span>
                <span>只做一刀</span>
                <span>不先规划</span>
              </div>
            </article>

            <article class="action-card reasons-card">
              <p class="card-kicker">为什么这张先出现</p>
              <ul id="action-reasons" class="reason-list">
                <li>动作足够小，不需要额外组织意志力</li>
                <li>开始本身会减少卡住感</li>
                <li>今天只要求推进，不要求完美</li>
              </ul>
            </article>

            <article class="action-card summary-card">
              <div class="summary-grid">
                <article>
                  <strong id="action-done-count">0</strong>
                  <span>已推进</span>
                </article>
                <article>
                  <strong id="action-momentum">0</strong>
                  <span>动量分</span>
                </article>
                <article>
                  <strong id="action-deferred-count">0</strong>
                  <span>稍后区</span>
                </article>
                <article>
                  <strong id="action-remaining">0</strong>
                  <span>剩余</span>
                </article>
              </div>
            </article>

            <article class="action-card receipt-card">
              <p class="card-kicker">今日收据</p>
              <ol id="action-receipts" class="receipt-list">
                <li>今天的第一刀还没落下。</li>
              </ol>
            </article>

            <div class="action-dock">
              <div class="action-grid">
                <button id="action-start" class="action-pill action-pill-primary" type="button">先做 3 分钟</button>
                <button id="action-later" class="action-pill" type="button">稍后</button>
                <button id="action-swap" class="action-pill action-pill-secondary" type="button">换一刀</button>
              </div>
              <div class="feedback-row">
                <button id="action-undo" class="ghost-btn ghost-btn-small" type="button">撤回</button>
                <p id="action-feedback">行动收银台已经就绪。输入一句任务，或直接载入一轮示例。</p>
              </div>
            </div>
          </div>

          <div class="review-stack">
            <article class="review-card">
              <div class="review-head">
                <div>
                  <p class="card-kicker">Momentum</p>
                  <h3>已推进</h3>
                </div>
                <div class="review-stat">
                  <strong id="action-done-count-mirror">0</strong>
                  <span>今天已经动过的刀</span>
                </div>
              </div>
              <p class="review-note">这里留下的不是任务墓地，而是今天已经发生过的推进。</p>
              <ol id="action-done-list" class="review-list">
                <li class="action-review-empty">还没有动作进入“已推进”。先做一刀，收据就会开始长出来。</li>
              </ol>
            </article>

            <article class="review-card">
              <div class="review-head">
                <div>
                  <p class="card-kicker">Later queue</p>
                  <h3>稍后区</h3>
                </div>
                <div class="review-stat">
                  <strong id="action-deferred-count-mirror">0</strong>
                  <span>今天先挪开的动作</span>
                </div>
              </div>
              <p class="review-note">今天不做也成立。真正好的行动产品，不会把“稍后”当成失败。</p>
              <ol id="action-deferred-list" class="review-list">
                <li class="action-review-empty">稍后区还是空的。今天不想现在做的动作，可以先安全挪开。</li>
              </ol>
              <div class="review-footer">
                <button id="action-restore-deferred" class="ghost-btn" type="button" disabled>把稍后区放回队列</button>
              </div>
            </article>

            <article class="review-card review-card-trust">
              <p class="card-kicker">Trust rules</p>
              <h3>行动收银台不是在替你装忙，而是在保护开始这件事。</h3>
              <ul class="trust-list">
                {trustRules.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </article>
          </div>
        </div>
      </section>

      <section class="content-section reveal">
        <div class="section-head">
          <div>
            <p class="section-tag">Sibling product</p>
            <h2>它不是取代下载区去留器，而是和它并列。</h2>
          </div>
          <p>文件收银台解决“留还是不留”，行动收银台解决“做还是不做、从哪开始”。两个方向都属于待结，但心智不能混。</p>
        </div>

        <div class="bridge-panel">
          <div>
            <p class="card-kicker">双主线</p>
            <h3>一个负责减对象，一个负责减阻力。</h3>
            <p>如果下载区去留器是“把文件杂物堆结掉”，那行动收银台就是“把启动阻力结掉”。它们后面可以并到同一个母产品里，但现在拆开更容易做顺。</p>
          </div>
          <div class="bridge-actions">
            <a class="hero-btn hero-btn-primary" href="/downloads-checkout/">打开下载区去留器</a>
            <a class="hero-btn hero-btn-secondary" href="/downloads-checkout/mobile/">看手机版下载区去留器</a>
            <a class="hero-btn hero-btn-secondary" href="/daijie/">回待结概念页</a>
          </div>
        </div>
      </section>

      <section id="faq" class="content-section reveal">
        <div class="section-head">
          <div>
            <p class="section-tag">FAQ</p>
            <h2>先把这条线最容易被问到的事答掉。</h2>
          </div>
          <p>这条产品线最容易跑偏成待办系统、鸡汤工具或复杂规划页。所以界限要先说清。</p>
        </div>

        <div class="faq-list">
          {faqItems.map((item) => (
            <details class="faq-item">
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>

        <div class="roadmap-grid">
          {roadmap.map((item) => (
            <article class="roadmap-card">
              <span>{item.phase}</span>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </section>
    </main>
  </div>

  <script is:inline id="action-checkout-bootstrap" type="application/json" set:html={JSON.stringify({
    presets: demoPresets,
    storageKey: "action-checkout:v1"
  })}></script>
  <script is:inline src="/action-checkout.js" defer></script>
  <script is:inline>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add("in-view");
      });
    }, { threshold: 0.12 });
    document.querySelectorAll(".reveal").forEach((node) => observer.observe(node));
  </script>

  <style>
    :root {
      --action-bg: #eef4ea;
      --action-paper: rgba(251, 248, 241, 0.94);
      --action-paper-strong: rgba(255, 252, 246, 0.97);
      --action-line: rgba(55, 71, 56, 0.12);
      --action-ink: #1f231f;
      --action-muted: #5e685e;
      --action-accent: #c86a3a;
      --action-accent-deep: #8b4a2b;
      --action-moss: #264032;
      --action-chip: rgba(39, 57, 44, 0.08);
    }

    :global(body) {
      background:
        radial-gradient(circle at top left, rgba(201, 223, 195, 0.7), transparent 28%),
        linear-gradient(180deg, #f7f3ea 0%, var(--action-bg) 100%);
      color: var(--action-ink);
    }

    .action-shell {
      width: min(1380px, calc(100vw - 32px));
      margin: 0 auto;
      padding: 24px 0 56px;
    }

    .action-header,
    .hero,
    .content-section,
    .bridge-panel,
    .faq-item,
    .roadmap-card {
      border: 1px solid var(--action-line);
      border-radius: 32px;
      background: var(--action-paper);
      box-shadow: 0 24px 48px rgba(39, 48, 36, 0.08);
