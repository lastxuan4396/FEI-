---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteConfig } from "../../config/site";
import {
  bestFirstMoves,
  convergencePath,
  dailyRhythm,
  demoCards,
  ideaCards,
  ideaFamilies,
  mvpFeatures,
  nonGoals,
  pageMeta,
  productAngles,
  queueTypes,
  quotes,
  roadmap
} from "../../data/daijie";

const familyCounts = ideaFamilies.map((family) => ({
  ...family,
  count: ideaCards.filter((idea) => idea.family === family.key).length
}));

const promiseCards = [
  {
    title: "不是又一个待办工具",
    body: "待结解决的是“悬而未决的小账”，不是把整个人生重新系统化。"
  },
  {
    title: "先结最容易继续的一笔",
    body: "排序逻辑不追求最重要，而追求最低启动阻力和最高连续性。"
  },
  {
    title: "每做一笔就轻一点",
    body: "反馈不是绩效打分，而是今天清掉了多少负担、释放了多少空间。"
  },
  {
    title: "从真实来源切进去",
    body: "第一版只先接 Downloads 和收藏夹，不做假需求，也不做大全。"
  }
] as const;

const workflowSteps = [
  {
    title: "收进待结",
    body: "文件、链接、消息、灵感进入队列，但不会一次性砸到你面前。"
  },
  {
    title: "一张一张结",
    body: "系统只给当前最容易继续的一笔，你只做一个动作，然后进入下一张。"
  },
  {
    title: "收据告诉你轻了多少",
    body: "处理数量、释放空间、今天的轻松感，会替代“又建了一个新系统”的空耗。"
  }
] as const;

const fitCards = [
  {
    title: "下载区永远像临时仓库的人",
    body: "截图、final-final、没来得及归档的文件堆着不动，不是不会整理，而是不想重新进入那个文件夹。"
  },
  {
    title: "收藏夹和稍后读越存越重的人",
    body: "真正压着你的不是没时间学，而是每次打开都要重新决定这篇到底还值不值得看。"
  },
  {
    title: "脑子里总有很多小尾巴的人",
    body: "你不需要更重的管理系统，只需要一个地方，把这些小账单一笔一笔结掉。"
  }
] as const;

const faqItems = [
  {
    question: "待结和普通待办工具最大的区别是什么？",
    answer: "待办工具让你管理任务，待结让你处理悬账。它面对的是那些一直挂着、但又不值得你建大系统的小决策。"
  },
  {
    question: "第一版最先会处理什么？",
    answer: "第一版只先做 Downloads 和收藏夹，把“信息债”和“文件债”这两类最真实、最容易验证的痛点跑顺。"
  },
  {
    question: "会不会自动删东西？",
    answer: "不会。待结的默认原则是可撤回、低风险。第一版更像“帮你做决定”，不是“替你偷偷执行”。"
  },
  {
    question: "为什么官网现在就上线？",
    answer: "因为这个产品首先需要一个清楚的外部形状。官网不是包装，它本身就是对产品定位和用户价值的一次收束。"
  }
] as const;
---
<BaseLayout
  title={pageMeta.title}
  description={pageMeta.description}
  image="/assets/daijie-cover.svg"
  canonical="/daijie/"
>
  <a class="skip-link" href="#daijie-main">跳到主要内容</a>

  <div class="daijie-shell">
    <header class="daijie-header">
      <a class="daijie-brand" href="/">
        <span class="daijie-brand-badge">待结</span>
        <span class="daijie-brand-copy">
          <strong>Life Checkout Counter</strong>
          <small>Official product site · Early access</small>
        </span>
      </a>

      <nav class="daijie-nav" aria-label="待结页面导航">
        <a href="#overview">概览</a>
        <a href="#why">为什么是它</a>
        <a href="#workflow">怎么工作</a>
        <a href="#demo">体验</a>
        <a href="#faq">FAQ</a>
        <a href="#waitlist">内测</a>
      </nav>

      <a class="daijie-home-link" href="/">回作品站</a>
    </header>

    <main id="daijie-main" class="daijie-main">
      <section id="overview" class="daijie-hero reveal">
        <div class="hero-copy">
          <p class="section-tag">Official site</p>
          <h1>让生活里的悬账，有出口。</h1>
          <p class="hero-lead">{pageMeta.pitch}</p>
          <p class="hero-note">
            待结不是整理系统，不是待办清单，也不是又一个强迫你自律的工具。
            它更像一台收银台，把那些一直挂着的小事排好队，让你一张一张结掉。
          </p>

          <div class="hero-actions">
            <a class="hero-btn hero-btn-primary" href="#demo">立即试用 MVP</a>
            <a class="hero-btn hero-btn-secondary" href="#waitlist">申请早期内测</a>
          </div>

          <div class="hero-metrics" aria-label="页面摘要指标">
            <article>
              <strong>3 分钟</strong>
              <span>完成一轮轻量结账</span>
            </article>
            <article>
              <strong>{queueTypes.length} 类</strong>
              <span>真实高频的生活悬账</span>
            </article>
            <article>
              <strong>100%</strong>
              <span>可撤回，先敢快再做准</span>
            </article>
          </div>
        </div>

        <div class="hero-board" aria-label="待结产品收据板">
          <article class="board-card board-card-origin">
            <p class="card-kicker">适合先收进来</p>
            <h2>下载文件、收藏链接、待回消息、零散灵感。</h2>
            <p>它们不够大，不值得建完整系统；但它们够频繁，足以持续占住你的注意力。</p>
          </article>

          <article class="board-card board-card-middle">
            <p class="card-kicker">待结的排序逻辑</p>
            <ul>
              <li>不是最重要的先来，而是最容易继续的先来</li>
              <li>每张卡只做一个动作</li>
              <li>先让人动起来，再慢慢做深</li>
            </ul>
          </article>

          <article class="board-card board-card-product">
            <p class="card-kicker">第一版先做什么</p>
            <h2>先跑顺 Downloads + 收藏夹。</h2>
            <p>先把文件债和信息债做顺，再决定消息、关系、购物冲动要不要接进来。</p>
            <div class="pill-row">
              <span>桌面优先</span>
              <span>轻交互</span>
              <span>可撤回</span>
            </div>
          </article>
        </div>
      </section>

      <section id="why" class="content-section reveal">
        <div class="section-head">
          <div>
            <p class="section-tag">Why it matters</p>
            <h2>待结想解决的，不是效率，而是“脑子里一直挂着”。</h2>
          </div>
          <p>
            真正消耗人的不是大任务，而是一堆小账单一直没结清。待结把这类负担做成一个轻量流程，而不是一个更重的系统。
          </p>
        </div>

        <div class="insight-grid">
          {promiseCards.map((insight) => (
            <article class="insight-card">
              <h3>{insight.title}</h3>
              <p>{insight.body}</p>
            </article>
          ))}
        </div>

        <div class="quote-strip" aria-label="关键句摘录">
          {quotes.map((quote) => (
            <span>{quote}</span>
          ))}
        </div>
      </section>

      <section id="workflow" class="content-section reveal">
        <div class="section-head">
          <div>
            <p class="section-tag">How it works</p>
            <h2>它不是帮你规划一切，而是帮你结下一笔。</h2>
          </div>
          <p>从进队列到做决定，再到看到收据，产品体验应该像一个轻量循环，而不是一个更复杂的控制台。</p>
        </div>

        <div class="workflow-grid">
          {workflowSteps.map((step, index) => (
            <article class="workflow-card">
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="content-section reveal">
        <div class="section-head">
          <div>
            <p class="section-tag">For who</p>
            <h2>它适合那些不缺方法，只缺一个轻一点入口的人。</h2>
          </div>
          <p>待结不是给重度效率玩家做的控制台。它更适合那些明明知道该处理，但总嫌开始太重、太烦、太像一个大工程的人。</p>
        </div>

        <div class="fit-grid">
          {fitCards.map((card) => (
            <article class="fit-card">
              <h3>{card.title}</h3>
              <p>{card.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="product" class="content-section reveal">
        <div class="section-head">
          <div>
            <p class="section-tag">Why this shape</p>
            <h2>为什么最后会收敛成“待结”，而不是 12 个分散的小 app。</h2>
          </div>
          <p>因为真正值得积累的是一个母产品：围绕悬账、去留、继续和收据感建立统一体验，而不是把每个场景都拆成孤岛。</p>
        </div>

        <div class="product-layout">
          <div class="convergence-steps">
            {convergencePath.map((item) => (
              <article class="step-card">
                <span>{item.step}</span>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </article>
            ))}
          </div>

          <div class="product-panel">
            <article class="panel-card">
              <p class="card-kicker">产品定义</p>
              <div class="angle-list">
                {productAngles.map((angle) => (
                  <article class="angle-item">
                    <strong>{angle.label}</strong>
                    <p>{angle.value}</p>
                  </article>
                ))}
              </div>
            </article>

            <article class="panel-card">
              <p class="card-kicker">四种悬账</p>
              <div class="queue-list">
                {queueTypes.map((queue) => (
                  <article class="queue-item">
                    <h3>{queue.name}</h3>
                    <p>{queue.items}</p>
                    <small>{queue.actions}</small>
                  </article>
                ))}
              </div>
            </article>
          </div>
        </div>
      </section>

      <section id="demo" class="content-section reveal">
        <div class="section-head">
          <div>
            <p class="section-tag">MVP beta</p>
            <h2>现在这块不只是 demo 了，已经能处理真实的 Downloads 和收藏夹。</h2>
          </div>
          <p>支持的浏览器里，你可以直接连接本地 Downloads 文件夹，或导入浏览器书签导出 HTML。所有分析都在当前浏览器里完成，不上传数据，队列也会自动保存在本机。</p>
        </div>

        <div class="mvp-layout">
          <article class="mvp-source-panel">
            <div class="mvp-source-head">
              <div>
                <p class="card-kicker">Source hub</p>
                <h3>先把待结队列接进来</h3>
              </div>
              <div class="mvp-chip-row">
                <span id="mvp-session-mode">示例队列已就绪</span>
                <span id="mvp-privacy-note">本地解析，本机自动保存</span>
              </div>
            </div>

            <div class="mvp-source-grid">
              <article class="source-card">
                <p class="card-kicker">Source 01</p>
                <h3>Downloads 文件夹</h3>
                <p>优先识别截图、安装包、临时文档和久未处理的大文件，先把最容易继续的一笔排前面。</p>
                <div class="source-actions">
                  <button id="mvp-connect-downloads" class="demo-btn demo-btn-primary" type="button">连接文件夹</button>
                  <label class="demo-btn source-upload">
                    选择文件夹
                    <input id="mvp-downloads-input" type="file" webkitdirectory directory multiple hidden />
                  </label>
                </div>
                <p id="mvp-downloads-status" class="source-status">
                  还没接入。Chrome / Edge 可直接连接文件夹，其他浏览器可手动选择。
                </p>
              </article>

              <article class="source-card">
                <p class="card-kicker">Source 02</p>
                <h3>浏览器收藏夹</h3>
                <p>导入书签导出 HTML 后，待结会按重复主题、存入时长和处理成本，生成信息账单队列。</p>
                <div class="source-actions">
                  <label class="demo-btn demo-btn-primary source-upload">
                    导入书签 HTML
                    <input id="mvp-bookmarks-input" type="file" accept=".html,text/html" hidden />
                  </label>
                </div>
                <p id="mvp-bookmarks-status" class="source-status">还没导入。建议直接用浏览器自带的“导出书签”文件。</p>
              </article>

              <article class="source-card">
                <p class="card-kicker">Source 03</p>
                <h3>归档文件夹</h3>
                <p>如果你在 Chrome / Edge 中连接一个归档目录，待结会在你点“归档”时先把文件复制进去，再留给你手动确认原文件是否清理。</p>
                <div class="source-actions">
                  <button id="mvp-connect-archive" class="demo-btn demo-btn-primary" type="button">连接归档文件夹</button>
                </div>
                <p id="mvp-archive-status" class="source-status">还没连接。待删不会直接删除，文件归档也默认先走安全路径。</p>
              </article>
            </div>

            <div class="mvp-source-footer">
              <div class="mvp-source-summary">
                <strong id="mvp-loaded-count">{demoCards.length}</strong>
                <span>当前队列</span>
              </div>
              <div class="mvp-source-summary">
                <strong id="mvp-source-count">0</strong>
                <span>已接来源</span>
              </div>
              <div class="mvp-utility-actions">
                <button id="mvp-export-drop-list" class="demo-btn" type="button" disabled>导出待删清单</button>
                <button id="mvp-load-sample" class="demo-btn" type="button">载入示例队列</button>
                <button id="mvp-clear-session" class="demo-btn" type="button">清空本轮</button>
              </div>
            </div>
          </article>

          <div class="demo-layout mvp-workspace">
            <article class="demo-console">
            <div class="demo-console-top">
              <div>
                <p class="card-kicker">今日收银台</p>
                <h3 id="mvp-queue-title">文件账单</h3>
              </div>
              <div class="queue-counter">
                <span id="mvp-index">1</span>
                <span>/</span>
                <span id="mvp-total">{demoCards.length}</span>
              </div>
            </div>

            <div id="mvp-card" class="demo-card">
              <p id="mvp-kicker" class="demo-card-kicker">Downloads</p>
              <h3 id="mvp-title">IMG_8473.PNG</h3>
              <p id="mvp-meta" class="demo-card-meta">截屏 · 14 天没打开 · 24.8 MB</p>
              <p id="mvp-message" class="demo-card-message">
                这类临时截图通常只在当下有用。现在看一眼，决定它还值不值得继续占空间。
              </p>
              <div id="mvp-tags" class="pill-row">
                <span>临时文件</span>
                <span>处理成本低</span>
                <span>适合先结</span>
              </div>
            </div>

            <div class="demo-actions">
              <button id="mvp-primary-action" class="demo-btn demo-btn-primary" type="button" data-mvp-action="process">打开看</button>
              <button class="demo-btn" type="button" data-mvp-action="later">稍后</button>
              <button id="mvp-archive-action" class="demo-btn" type="button" data-mvp-action="archive">归档</button>
              <button id="mvp-drop-action" class="demo-btn demo-btn-danger" type="button" data-mvp-action="drop">待删</button>
            </div>

            <div class="demo-feedback-row">
              <button id="mvp-undo" class="demo-undo" type="button">撤回上一笔</button>
              <p id="mvp-feedback">示例队列已经就绪。你也可以直接接入自己的 Downloads 和收藏夹。</p>
            </div>
          </article>

          <aside class="demo-sidebar">
            <article class="sidebar-card">
              <p class="card-kicker">为什么这张先出现</p>
              <ul id="mvp-reasons" class="reason-list">
                <li>久未处理，但判断成本低</li>
                <li>不会牵出新的复杂步骤</li>
                <li>先赢一笔，更容易继续</li>
              </ul>
            </article>

            <article class="sidebar-card">
              <p class="card-kicker">本轮结算</p>
              <div class="summary-grid">
                <article>
                  <strong id="mvp-processed">0</strong>
                  <span>已处理</span>
                </article>
                <article>
                  <strong id="mvp-released">0.0 MB</strong>
                  <span>释放空间</span>
                </article>
                <article>
                  <strong id="mvp-lightness">0</strong>
                  <span>轻松感分值</span>
                </article>
                <article>
                  <strong id="mvp-remaining">{demoCards.length}</strong>
                  <span>剩余悬账</span>
                </article>
              </div>
            </article>

            <article class="sidebar-card">
              <p class="card-kicker">今日收据</p>
              <ol id="mvp-receipts" class="receipt-list">
                <li>等待第一笔结账...</li>
              </ol>
            </article>
          </aside>
          </div>
        </div>
      </section>

      <section id="waitlist" class="content-section reveal">
        <div class="section-head">
          <div>
            <p class="section-tag">Early access</p>
            <h2>产品已经开跑，早期内测名单继续收起来。</h2>
          </div>
          <p>
            第一版先把 Downloads 和收藏夹做成真能用的浏览器端 MVP。内测阶段更重视的是，你最想先清什么债，以及这套节奏有没有真的帮你轻下来。
          </p>
        </div>

        <div class="waitlist-panel">
          <div class="waitlist-copy">
            <p class="card-kicker">当前阶段</p>
            <h3>产品 Beta</h3>
            <p>
              现在这页已经不是纯官网了，里面带着一个浏览器端 MVP。你可以直接接入本地 Downloads、导入书签 HTML，再一张张结掉真实的文件债和信息债。
            </p>
            <div class="pill-row">
              <span>桌面优先</span>
              <span>从真实来源开始</span>
              <span>申请内测</span>
            </div>
          </div>

          <form
            id="waitlist-form"
            class="waitlist-form"
            data-waitlist-to={siteConfig.email}
          >
            <label>
              <span>你的邮箱</span>
              <input id="waitlist-email" type="email" name="email" placeholder="you@example.com" required />
            </label>

            <label>
              <span>你最想先清什么</span>
              <select id="waitlist-focus" name="focus">
                <option value="Downloads 文件债">Downloads 文件债</option>
                <option value="收藏夹信息债">收藏夹信息债</option>
                <option value="待回消息">待回消息</option>
                <option value="灵感和购物冲动">灵感和购物冲动</option>
              </select>
            </label>

            <label>
              <span>一句话说说你的场景</span>
              <textarea id="waitlist-note" name="note" rows="4" placeholder="例如：我的 Downloads 里总有一堆临时截图和 final-final 文件。"></textarea>
            </label>

            <button class="hero-btn hero-btn-primary waitlist-submit" type="submit">申请早期内测</button>
            <p id="waitlist-feedback" class="waitlist-feedback">
              提交后会直接帮你打开邮件客户端，收件邮箱是 <strong>{siteConfig.email}</strong>。
            </p>
          </form>
        </div>
      </section>

      <section id="faq" class="content-section reveal">
        <div class="section-head">
          <div>
            <p class="section-tag">FAQ</p>
            <h2>先把几个最像真产品会被问到的问题答掉。</h2>
          </div>
          <p>产品官网不只是好看，还要能回答“它到底是什么、先做什么、为什么值得等”。</p>
        </div>

        <div class="faq-grid">
          {faqItems.map((item) => (
            <details class="faq-item">
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <section id="roadmap" class="content-section reveal">
        <div class="section-head">
          <div>
            <p class="section-tag">Roadmap</p>
            <h2>如果真要做，这个产品应该先怎么长。</h2>
          </div>
          <p>这部分把“现在就能开始做什么”和“先不要做什么”都明确下来，避免下一步又散掉。</p>
        </div>

        <div class="roadmap-layout">
          <article class="roadmap-card">
            <p class="card-kicker">MVP 只做这些</p>
            <ul class="roadmap-list">
              {mvpFeatures.map((feature) => (
                <li>{feature}</li>
              ))}
            </ul>
          </article>

