---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  bestFirstMoves,
  convergencePath,
  dailyRhythm,
  demoCards,
  distilledInsights,
  ideaCards,
  ideaFamilies,
  mvpFeatures,
  nonGoals,
  pageMeta,
  productAngles,
  queueTypes,
  quotes,
  roadmap
} from "../../data/daijie";

const familyCounts = ideaFamilies.map((family) => ({
  ...family,
  count: ideaCards.filter((idea) => idea.family === family.key).length
}));
---
<BaseLayout
  title={pageMeta.title}
  description={pageMeta.description}
  image="/assets/daijie-cover.svg"
  canonical="/daijie/"
>
  <a class="skip-link" href="#daijie-main">跳到主要内容</a>

  <div class="daijie-shell">
    <header class="daijie-header">
      <a class="daijie-brand" href="/">
        <span class="daijie-brand-badge">待结</span>
        <span class="daijie-brand-copy">
          <strong>Life Checkout Counter</strong>
          <small>从一次对话里长出来的产品页面</small>
        </span>
      </a>

      <nav class="daijie-nav" aria-label="待结页面导航">
        <a href="#overview">概览</a>
        <a href="#insights">结论</a>
        <a href="#ideas">创意库</a>
        <a href="#product">产品化</a>
        <a href="#demo">体验</a>
        <a href="#roadmap">路线</a>
      </nav>

      <a class="daijie-home-link" href="/">回作品站</a>
    </header>

    <main id="daijie-main" class="daijie-main">
      <section id="overview" class="daijie-hero reveal">
        <div class="hero-copy">
          <p class="section-tag">Conversation to Product</p>
          <h1>把“我也可以做软件”变成一个真的产品方向。</h1>
          <p class="hero-lead">{pageMeta.pitch}</p>
          <p class="hero-note">{pageMeta.heroNote}</p>

          <div class="hero-actions">
            <a class="hero-btn hero-btn-primary" href="#demo">先试一笔</a>
            <a class="hero-btn hero-btn-secondary" href="#ideas">看 12 个方向怎么收敛</a>
          </div>

          <div class="hero-metrics" aria-label="页面摘要指标">
            <article>
              <strong>{ideaCards.length}</strong>
              <span>对话里长出的创意方向</span>
            </article>
            <article>
              <strong>{queueTypes.length}</strong>
              <span>最终收敛出的悬账队列</span>
            </article>
            <article>
              <strong>2</strong>
              <span>第一版先接的真实来源</span>
            </article>
          </div>
        </div>

        <div class="hero-board" aria-label="对话收据板">
          <article class="board-card board-card-origin">
            <p class="card-kicker">起点</p>
            <h2>看见成熟产品后，意识到自己也可以做软件。</h2>
            <p>不是靠技术炫技，而是靠抓住一种真实的卡点，然后把那个卡点做得顺。</p>
          </article>

          <article class="board-card board-card-middle">
            <p class="card-kicker">共同结构</p>
            <ul>
              <li>把复杂判断压缩成小动作</li>
              <li>让人持续往前，不在起步时就卡住</li>
              <li>软件价值来自交互节奏和心理推动</li>
            </ul>
          </article>

          <article class="board-card board-card-product">
            <p class="card-kicker">今天的产品结论</p>
            <h2>人生待处理收银台</h2>
            <p>最后继续收敛成一个更像产品名的词：<strong>待结</strong>。</p>
            <div class="pill-row">
              <span>悬账</span>
              <span>结账</span>
              <span>轻一点</span>
            </div>
          </article>
        </div>
      </section>

      <section id="insights" class="content-section reveal">
        <div class="section-head">
          <div>
            <p class="section-tag">What Actually Matters</p>
            <h2>这段对话真正沉淀下来的，是一套产品判断。</h2>
          </div>
          <p>
            它不是“灵感列表”，而是对什么样的软件值得做、该怎么开始做、做成什么形状，形成了一条清晰路径。
          </p>
        </div>

        <div class="insight-grid">
          {distilledInsights.map((insight) => (
            <article class="insight-card">
              <h3>{insight.title}</h3>
              <p>{insight.body}</p>
            </article>
          ))}
        </div>

        <div class="quote-strip" aria-label="关键句摘录">
          {quotes.map((quote) => (
            <span>{quote}</span>
          ))}
        </div>
      </section>

      <section id="ideas" class="content-section reveal">
        <div class="section-head">
          <div>
            <p class="section-tag">Idea Bank</p>
            <h2>创意不是散的，它们都在围着同一个母题打转。</h2>
          </div>
          <p>筛一下就能看出来：你喜欢的并不是某个单点功能，而是一类“降低决策阻力”的软件。</p>
        </div>

        <div class="idea-toolbar">
          <div class="family-tabs" role="tablist" aria-label="创意分类筛选">
            <button class="family-tab active" type="button" data-idea-filter="all" aria-pressed="true">全部</button>
            {familyCounts.map((family) => (
              <button class="family-tab" type="button" data-idea-filter={family.key} aria-pressed="false">
                {family.label} · {family.count}
              </button>
            ))}
          </div>
          <p id="idea-count" class="idea-count">当前显示 {ideaCards.length} 个方向</p>
        </div>

        <div class="idea-layout">
          <div class="idea-grid">
            {ideaCards.map((idea) => (
              <article class="idea-card" data-idea-family={idea.family}>
                <p class="card-kicker">{ideaFamilies.find((family) => family.key === idea.family)?.label}</p>
                <h3>{idea.title}</h3>
                <p class="idea-one-liner">{idea.oneLiner}</p>
                <p class="idea-why">{idea.whyItWorks}</p>
              </article>
            ))}
          </div>

          <aside class="idea-sidebar">
            <article class="sidebar-card">
              <p class="card-kicker">最适合起步的三个方向</p>
              <div class="stack-list">
                {bestFirstMoves.map((move) => (
                  <article class="stack-item">
                    <h3>{move.title}</h3>
                    <p>{move.reason}</p>
                  </article>
                ))}
              </div>
            </article>

            <article class="sidebar-card">
              <p class="card-kicker">三大创意家族</p>
              <div class="family-note-list">
                {familyCounts.map((family) => (
                  <article>
                    <strong>{family.label}</strong>
                    <p>{family.summary}</p>
                  </article>
                ))}
              </div>
            </article>
          </aside>
        </div>
      </section>

      <section id="product" class="content-section reveal">
        <div class="section-head">
          <div>
            <p class="section-tag">Convergence</p>
            <h2>从很多点子，到“人生待处理收银台”，再到待结。</h2>
          </div>
          <p>这个页面最核心的价值，不是多讲了一遍，而是把收敛过程变得可回看、可复用、可继续长。</p>
        </div>

        <div class="product-layout">
          <div class="convergence-steps">
            {convergencePath.map((item) => (
              <article class="step-card">
                <span>{item.step}</span>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </article>
            ))}
          </div>

          <div class="product-panel">
            <article class="panel-card">
              <p class="card-kicker">产品定义</p>
              <div class="angle-list">
                {productAngles.map((angle) => (
                  <article class="angle-item">
                    <strong>{angle.label}</strong>
                    <p>{angle.value}</p>
                  </article>
                ))}
              </div>
            </article>

            <article class="panel-card">
              <p class="card-kicker">四种悬账</p>
              <div class="queue-list">
                {queueTypes.map((queue) => (
                  <article class="queue-item">
                    <h3>{queue.name}</h3>
                    <p>{queue.items}</p>
                    <small>{queue.actions}</small>
                  </article>
                ))}
              </div>
            </article>
          </div>
        </div>
      </section>

      <section id="demo" class="content-section reveal">
        <div class="section-head">
          <div>
            <p class="section-tag">Interactive Demo</p>
            <h2>试一笔，你会更明白“结账”到底是什么意思。</h2>
          </div>
          <p>下面这块是可操作的。它把对话里的核心体验直接翻成一个小收银台：一张卡、一个动作、立刻反馈。</p>
        </div>

        <div class="demo-layout">
          <article class="demo-console">
            <div class="demo-console-top">
              <div>
                <p class="card-kicker">今日收银台</p>
                <h3 id="demo-queue-title">文件账单</h3>
              </div>
              <div class="queue-counter">
                <span id="demo-index">1</span>
                <span>/</span>
                <span id="demo-total">{demoCards.length}</span>
              </div>
            </div>

            <div id="demo-card" class="demo-card">
              <p id="demo-kicker" class="demo-card-kicker">Downloads</p>
              <h3 id="demo-title">IMG_8473.PNG</h3>
              <p id="demo-meta" class="demo-card-meta">截屏 · 14 天没打开 · 24.8 MB</p>
              <p id="demo-message" class="demo-card-message">
                这类临时截图通常只在当下有用。现在看一眼，决定它还值不值得继续占空间。
              </p>
              <div id="demo-tags" class="pill-row">
                <span>临时文件</span>
                <span>处理成本低</span>
                <span>适合先结</span>
              </div>
            </div>

            <div class="demo-actions">
              <button class="demo-btn demo-btn-primary" type="button" data-demo-action="process">现在处理</button>
              <button class="demo-btn" type="button" data-demo-action="later">稍后</button>
              <button class="demo-btn" type="button" data-demo-action="archive">归档</button>
              <button class="demo-btn demo-btn-danger" type="button" data-demo-action="drop">丢掉</button>
            </div>

            <div class="demo-feedback-row">
              <button id="demo-undo" class="demo-undo" type="button">撤回上一笔</button>
              <p id="demo-feedback">还没开始。先结一笔看看。</p>
            </div>
          </article>

          <aside class="demo-sidebar">
            <article class="sidebar-card">
              <p class="card-kicker">为什么这张先出现</p>
              <ul id="demo-reasons" class="reason-list">
                <li>久未处理，但判断成本低</li>
                <li>不会牵出新的复杂步骤</li>
                <li>先赢一笔，更容易继续</li>
              </ul>
            </article>

            <article class="sidebar-card">
              <p class="card-kicker">本轮结算</p>
              <div class="summary-grid">
                <article>
                  <strong id="demo-processed">0</strong>
                  <span>已处理</span>
                </article>
                <article>
                  <strong id="demo-released">0.0 MB</strong>
                  <span>释放空间</span>
                </article>
                <article>
                  <strong id="demo-lightness">0</strong>
                  <span>轻松感分值</span>
                </article>
                <article>
                  <strong id="demo-remaining">{demoCards.length}</strong>
                  <span>剩余悬账</span>
                </article>
              </div>
            </article>

            <article class="sidebar-card">
              <p class="card-kicker">今日收据</p>
              <ol id="demo-receipts" class="receipt-list">
                <li>等待第一笔结账...</li>
              </ol>
            </article>
          </aside>
        </div>
      </section>

      <section id="roadmap" class="content-section reveal">
        <div class="section-head">
          <div>
            <p class="section-tag">Roadmap</p>
            <h2>如果真要做，这个产品应该先怎么长。</h2>
          </div>
          <p>这部分把“现在就能开始做什么”和“先不要做什么”都明确下来，避免下一步又散掉。</p>
        </div>

        <div class="roadmap-layout">
          <article class="roadmap-card">
            <p class="card-kicker">MVP 只做这些</p>
            <ul class="roadmap-list">
              {mvpFeatures.map((feature) => (
                <li>{feature}</li>
              ))}
            </ul>
          </article>

          <article class="roadmap-card">
            <p class="card-kicker">暂时别做这些</p>
            <ul class="roadmap-list muted">
              {nonGoals.map((feature) => (
                <li>{feature}</li>
              ))}
            </ul>
          </article>
        </div>

        <div class="timeline-layout">
          <div class="rhythm-grid">
            {dailyRhythm.map((item) => (
              <article class="rhythm-card">
                <span>{item.stage}</span>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </article>
            ))}
          </div>

          <div class="phase-grid">
            {roadmap.map((item) => (
              <article class="phase-card">
                <p class="card-kicker">{item.phase}</p>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="content-section reveal">
        <div class="closing-panel">
          <div>
            <p class="section-tag">One Line Close</p>
            <h2>待结不要求你把人生理顺，只要求你结掉下一笔小账。</h2>
            <p>
              这页把这次对话里最有价值的内容都收在一起了：为什么这个方向成立、能长出哪些产品、为什么最后会收敛成待结，以及第一版到底该怎么开工。
            </p>
          </div>

          <div class="closing-actions">
            <a class="hero-btn hero-btn-primary" href="#overview">回到开头</a>
            <a class="hero-btn hero-btn-secondary" href="/">回作品站</a>
          </div>
        </div>
      </section>
    </main>
  </div>

  <script is:inline id="daijie-demo-data" type="application/json" set:html={JSON.stringify(demoCards)}></script>

  <script is:inline>
    const revealItems = document.querySelectorAll(".reveal");
    const observer = "IntersectionObserver" in window
      ? new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) entry.target.classList.add("in-view");
          });
        }, { threshold: 0.12, rootMargin: "0px 0px -8% 0px" })
      : null;

    if (observer) {
      revealItems.forEach((item) => observer.observe(item));
    } else {
      revealItems.forEach((item) => item.classList.add("in-view"));
    }

    const familyButtons = document.querySelectorAll("[data-idea-filter]");
    const ideaCards = document.querySelectorAll("[data-idea-family]");
    const ideaCount = document.getElementById("idea-count");

    const updateIdeaCount = () => {
      if (!ideaCount) return;
      const count = [...ideaCards].filter((card) => !card.classList.contains("is-hidden")).length;
      ideaCount.textContent = `当前显示 ${count} 个方向`;
    };

    const applyIdeaFilter = (filter) => {
      familyButtons.forEach((button) => {
        const active = button.dataset.ideaFilter === filter;
        button.classList.toggle("active", active);
        button.setAttribute("aria-pressed", String(active));
      });

      ideaCards.forEach((card) => {
        const family = card.dataset.ideaFamily;
        card.classList.toggle("is-hidden", filter !== "all" && family !== filter);
      });

      updateIdeaCount();
    };

    familyButtons.forEach((button) => {
      button.addEventListener("click", () => {
        applyIdeaFilter(button.dataset.ideaFilter || "all");
      });
    });

    updateIdeaCount();

    const demoData = JSON.parse(document.getElementById("daijie-demo-data")?.textContent || "[]");
    const demoState = {
      index: 0,
      processed: 0,
      released: 0,
      lightness: 0,
      receipts: [],
      history: []
    };

    const demoQueueTitle = document.getElementById("demo-queue-title");
    const demoIndex = document.getElementById("demo-index");
    const demoTotal = document.getElementById("demo-total");
    const demoKicker = document.getElementById("demo-kicker");
    const demoTitle = document.getElementById("demo-title");
    const demoMeta = document.getElementById("demo-meta");
    const demoMessage = document.getElementById("demo-message");
    const demoTags = document.getElementById("demo-tags");
    const demoReasons = document.getElementById("demo-reasons");
    const demoProcessed = document.getElementById("demo-processed");
    const demoReleased = document.getElementById("demo-released");
    const demoLightness = document.getElementById("demo-lightness");
    const demoRemaining = document.getElementById("demo-remaining");
    const demoReceipts = document.getElementById("demo-receipts");
    const demoFeedback = document.getElementById("demo-feedback");
    const demoUndo = document.getElementById("demo-undo");
    const demoButtons = document.querySelectorAll("[data-demo-action]");
    const demoCard = document.getElementById("demo-card");

    if (demoTotal) demoTotal.textContent = String(demoData.length);

    const renderDemoTags = (tags) => {
      if (!demoTags) return;
      demoTags.innerHTML = "";
      tags.forEach((tag) => {
        const node = document.createElement("span");
        node.textContent = tag;
        demoTags.appendChild(node);
      });
    };

    const renderDemoReasons = (reasons) => {
      if (!demoReasons) return;
      demoReasons.innerHTML = "";
      reasons.forEach((reason) => {
        const item = document.createElement("li");
        item.textContent = reason;
        demoReasons.appendChild(item);
      });
    };

    const renderDemoReceipts = () => {
      if (!demoReceipts) return;
      demoReceipts.innerHTML = "";

      if (demoState.receipts.length === 0) {
        const item = document.createElement("li");
        item.textContent = "等待第一笔结账...";
        demoReceipts.appendChild(item);
        return;
      }

      demoState.receipts.slice().reverse().forEach((receipt) => {
        const item = document.createElement("li");
        item.textContent = receipt;
        demoReceipts.appendChild(item);
      });
    };

    const updateDemoSummary = () => {
      if (demoProcessed) demoProcessed.textContent = String(demoState.processed);
      if (demoReleased) demoReleased.textContent = `${demoState.released.toFixed(1)} MB`;
      if (demoLightness) demoLightness.textContent = String(demoState.lightness);
      if (demoRemaining) demoRemaining.textContent = String(Math.max(demoData.length - demoState.processed, 0));
      if (demoUndo) demoUndo.disabled = demoState.history.length === 0;
    };

    const demoBackgrounds = [
      "linear-gradient(145deg, rgba(255,255,255,0.98), rgba(250,231,203,0.92))",
      "linear-gradient(145deg, rgba(255,255,255,0.98), rgba(245,224,220,0.92))",
      "linear-gradient(145deg, rgba(255,255,255,0.98), rgba(220,239,228,0.92))",
      "linear-gradient(145deg, rgba(255,255,255,0.98), rgba(227,229,238,0.92))"
    ];

    const renderDemoCard = () => {
      const card = demoData[demoState.index];

      if (!card) {
        if (demoQueueTitle) demoQueueTitle.textContent = "今日结清";
        if (demoIndex) demoIndex.textContent = String(demoData.length);
        if (demoKicker) demoKicker.textContent = "Receipt";
        if (demoTitle) demoTitle.textContent = "这轮收银台已经结完了。";
        if (demoMeta) demoMeta.textContent = "你没有整理人生，只是放下了几笔一直挂着的小账。";
        if (demoMessage) demoMessage.textContent = "好的节奏不是一次性清空，而是明天还愿意继续回来。";
        renderDemoTags(["今日完成", "可以明天再来", "轻一点"]);
        renderDemoReasons(["本轮 demo 已完成", "用户获得轻松感而不是压力", "可撤回上一笔，不必怕做错"]);
        demoButtons.forEach((button) => {
          button.disabled = true;
        });
        return;
      }

      if (demoQueueTitle) demoQueueTitle.textContent = card.queue;
      if (demoIndex) demoIndex.textContent = String(demoState.index + 1);
      if (demoKicker) demoKicker.textContent = card.kicker;
      if (demoTitle) demoTitle.textContent = card.title;
      if (demoMeta) demoMeta.textContent = card.meta;
      if (demoMessage) demoMessage.textContent = card.message;
      renderDemoTags(card.tags);
      renderDemoReasons(card.reasons);
      if (demoCard) demoCard.style.background = demoBackgrounds[demoState.index % demoBackgrounds.length];
      demoButtons.forEach((button) => {
        button.disabled = false;
      });
    };

    const labelForAction = (action) => {
      switch (action) {
        case "process":
          return "现在处理";
        case "later":
          return "稍后";
        case "archive":
          return "归档";
        case "drop":
          return "丢掉";
        default:
          return "处理";
      }
    };

    const applyDemoAction = (action) => {
      const card = demoData[demoState.index];
      if (!card) return;

      demoState.history.push({
        index: demoState.index,
        processed: demoState.processed,
        released: demoState.released,
        lightness: demoState.lightness,
        receipts: [...demoState.receipts]
      });

      demoState.index += 1;
      demoState.processed += 1;
      demoState.released += action === "drop" || action === "archive" ? card.release : 0;
      demoState.lightness += action === "process" ? 18 : action === "drop" ? 16 : action === "archive" ? 14 : 10;
      demoState.receipts.push(`${labelForAction(action)} · ${card.title}`);

      if (demoFeedback) {
        demoFeedback.textContent = `${labelForAction(action)}了「${card.title}」，脑子里又少挂了一件事。`;
      }

      updateDemoSummary();
      renderDemoReceipts();
      renderDemoCard();
    };

    const undoDemoAction = () => {
      const previous = demoState.history.pop();
      if (!previous) return;

      demoState.index = previous.index;
      demoState.processed = previous.processed;
      demoState.released = previous.released;
      demoState.lightness = previous.lightness;
      demoState.receipts = previous.receipts;

      if (demoFeedback) {
        demoFeedback.textContent = "已撤回上一笔。做决定不该因为怕错而变慢。";
      }

      updateDemoSummary();
      renderDemoReceipts();
      renderDemoCard();
    };

    demoButtons.forEach((button) => {
      button.addEventListener("click", () => {
        applyDemoAction(button.dataset.demoAction);
      });
    });

    demoUndo?.addEventListener("click", undoDemoAction);

    updateDemoSummary();
    renderDemoReceipts();
    renderDemoCard();
  </script>

  <style>
    .daijie-shell {
      --paper: #f7efe1;
      --paper-strong: #fff8ee;
      --paper-soft: rgba(255, 249, 241, 0.76);
      --ink: #201a15;
      --muted: #64584d;
