  <script is:inline>
    const revealItems = document.querySelectorAll(".reveal");
    const observer = "IntersectionObserver" in window
      ? new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) entry.target.classList.add("in-view");
          });
        }, { threshold: 0.12, rootMargin: "0px 0px -8% 0px" })
      : null;

    if (observer) {
      revealItems.forEach((item) => observer.observe(item));
    } else {
      revealItems.forEach((item) => item.classList.add("in-view"));
    }

    const familyButtons = document.querySelectorAll("[data-idea-filter]");
    const ideaCards = document.querySelectorAll("[data-idea-family]");
    const ideaCount = document.getElementById("idea-count");

    const updateIdeaCount = () => {
      if (!ideaCount) return;
      const count = [...ideaCards].filter((card) => !card.classList.contains("is-hidden")).length;
      ideaCount.textContent = `当前显示 ${count} 个方向`;
    };

    const applyIdeaFilter = (filter) => {
      familyButtons.forEach((button) => {
        const active = button.dataset.ideaFilter === filter;
        button.classList.toggle("active", active);
        button.setAttribute("aria-pressed", String(active));
      });

      ideaCards.forEach((card) => {
        const family = card.dataset.ideaFamily;
        card.classList.toggle("is-hidden", filter !== "all" && family !== filter);
      });

      updateIdeaCount();
    };

    familyButtons.forEach((button) => {
      button.addEventListener("click", () => {
        applyIdeaFilter(button.dataset.ideaFilter || "all");
      });
    });

    updateIdeaCount();

    const waitlistForm = document.getElementById("waitlist-form");
    const waitlistEmail = document.getElementById("waitlist-email");
    const waitlistFocus = document.getElementById("waitlist-focus");
    const waitlistNote = document.getElementById("waitlist-note");
    const waitlistFeedback = document.getElementById("waitlist-feedback");

    waitlistForm?.addEventListener("submit", (event) => {
      event.preventDefault();

      const email = waitlistEmail?.value?.trim() || "";
      const focus = waitlistFocus?.value || "Downloads 文件债";
      const note = waitlistNote?.value?.trim() || "我想进一步了解待结的内测计划。";
      const to = waitlistForm.dataset.waitlistTo || "";

      if (!/.+@.+\..+/.test(email)) {
        if (waitlistFeedback) waitlistFeedback.textContent = "先填一个有效邮箱，再申请内测。";
        waitlistEmail?.focus();
        return;
      }

      const subject = encodeURIComponent(`待结内测申请 | ${focus}`);
      const body = encodeURIComponent(
        `邮箱：${email}\n最想先清的债：${focus}\n\n我的场景：\n${note}\n`
      );

      if (waitlistFeedback) {
        waitlistFeedback.textContent = `已为你打开邮件客户端，收件邮箱是 ${to}。`;
      }

      window.location.href = `mailto:${to}?subject=${subject}&body=${body}`;
    });
  </script>

