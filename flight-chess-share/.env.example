# Server
PORT=10000
NODE_ENV=development
APP_VERSION=2.3.0

# Security
LOG_SIGNING_SECRET=replace_with_random_secret
CORS_ALLOW_ORIGINS=http://localhost:10000,http://127.0.0.1:10000
# CORS_ALLOW_ALL=0

# Persistence
REDIS_URL=
REDIS_PREFIX=flightchess
SESSION_TTL_MS=1800000
DEFAULT_RULE_PACK=classic
